{
  "name": "parabank-playwright-framework",
  "version": "1.0.0",
  "description": "Production-ready Playwright JavaScript automation framework for ParaBank",
  "scripts": {
    "test": "playwright test --config=playwright.config.js",
    "test:headed": "playwright test --config=playwright.config.js --headed",
    "test:auth": "playwright test --config=playwright.config.js tests/auth.spec.js",
    "test:accounts": "playwright test --config=playwright.config.js tests/accounts.spec.js",
    "test:transactions": "playwright test --config=playwright.config.js tests/transactions.spec.js",
    "test:services": "playwright test --config=playwright.config.js tests/services.spec.js",
    "allure:generate": "allure generate -o allure-report allure-results",
    "allure:open": "allure open allure-report",
    "test:report": "npm run allure:generate && npm run allure:open",
    "test:allure": "npm test && npm run test:report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "allure": "^3.11.0",
    "allure-commandline": "^2.42.1",
    "allure-playwright": "^3.10.0"
  }
}
